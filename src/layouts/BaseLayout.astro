---
import { business, navLinks } from "../data/site";
import SocialLinks from "../components/SocialLinks.astro";
import NavIcon from "../components/NavIcon.astro";
import QuoteModal from "../components/QuoteModal.astro";
import JsonLd from "../components/JsonLd.astro";
import AnalyticsEvents from "../components/AnalyticsEvents.astro";
import GoogleTag from "../components/GoogleTag.astro";
import {
  buildLocalBusinessSchema,
  buildWebSiteSchema,
  getCanonicalUrl,
  siteUrl,
} from "../lib/seo";

interface Props {
  title: string;
  description?: string;
  current?: (typeof navLinks)[number]["key"];
  ogImage?: string;
  noindex?: boolean;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = `${business.name} — Complete IT solutions for Temecula businesses since ${business.temeculaSince}. Managed IT, backup, and support. Your in-office technician.`,
  current,
  ogImage = "/images/logo.png",
  noindex = false,
  structuredData,
} = Astro.props;

const fullTitle = title === business.name ? `${business.name} | Managed IT Services` : `${title} · ${business.shortName}`;
const logoSrc = "/images/logo.png";
const canonicalUrl = getCanonicalUrl(Astro.url.pathname);
const ogImageUrl = new URL(ogImage, siteUrl).href;
const gscVerification = import.meta.env.PUBLIC_GSC_VERIFICATION;

const defaultStructuredData = [buildLocalBusinessSchema(), buildWebSiteSchema()];
const jsonLd = structuredData
  ? [...defaultStructuredData, ...(Array.isArray(structuredData) ? structuredData : [structuredData])]
  : defaultStructuredData;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={business.name} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {gscVerification && <meta name="google-site-verification" content={gscVerification} />}

    <JsonLd data={jsonLd} />
    <GoogleTag />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>

    <header class="site-header">
      <div class="header-utility">
        <div class="header-utility-inner">
          <SocialLinks />
        </div>
      </div>
      <div class="nav-inner">
        <a class="brand" href="/">
          <img
            class="brand-logo"
            src={logoSrc}
            alt={business.name}
            width="200"
            height="142"
            onerror="this.hidden=true"
          />
        </a>
        <nav class="site-nav" aria-label="Main">
          <ul>
            {
              navLinks.map((link) => (
                <li>
                  <a href={link.href} aria-current={current === link.key ? "page" : undefined}>
                    <NavIcon name={link.key} />
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
        <div class="nav-end">
          <a class="nav-contact" href={`tel:${business.phoneTel}`} data-analytics-event="phone_click">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path
                d="M6.6 10.8a15.9 15.9 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.24 10.9 10.9 0 0 0 3.4.55 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1 10.9 10.9 0 0 0 .55 3.4 1 1 0 0 1-.24 1z"
              ></path>
            </svg>
            {business.phone}
          </a>
          <button class="nav-contact" type="button" data-open-quote data-analytics-event="consultation_modal_open">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path
                d="M4 4h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2zm0 2v.2l8 5 8-5V6H4zm16 12V9.3l-7.4 4.6a1 1 0 0 1-1.2 0L4 9.3V18h16z"
              ></path>
            </svg>
            Email us
          </button>
        </div>
        <button
          class="nav-toggle"
          type="button"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <span class="nav-toggle-icon" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </span>
          <span class="nav-toggle-text">Menu</span>
        </button>
      </div>

      <div id="mobile-menu" class="mobile-menu" hidden>
        <nav aria-label="Main mobile">
          <ul>
            {
              navLinks.map((link) => (
                <li>
                  <a href={link.href} aria-current={current === link.key ? "page" : undefined}>
                    <NavIcon name={link.key} />
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
        <div class="mobile-menu-actions">
          <SocialLinks class="social-links-mobile" />
          <a class="nav-contact" href={`tel:${business.phoneTel}`} data-analytics-event="phone_click">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path
                d="M6.6 10.8a15.9 15.9 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.24 10.9 10.9 0 0 0 3.4.55 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1 10.9 10.9 0 0 0 .55 3.4 1 1 0 0 1-.24 1z"
              ></path>
            </svg>
            {business.phone}
          </a>
          <button class="nav-contact" type="button" data-open-quote data-analytics-event="consultation_modal_open">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path
                d="M4 4h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2zm0 2v.2l8 5 8-5V6H4zm16 12V9.3l-7.4 4.6a1 1 0 0 1-1.2 0L4 9.3V18h16z"
              ></path>
            </svg>
            Email us
          </button>
        </div>
      </div>
    </header>

    <div id="form-success-banner" class="form-success-banner" role="status" hidden>
      <p>Thanks — we received your request and will be in touch soon.</p>
      <button type="button" class="form-success-dismiss" aria-label="Dismiss">×</button>
    </div>

    <main id="main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <a class="footer-brand" href="/">
          <img class="footer-logo" src={logoSrc} alt={business.name} width="200" height="142" />
        </a>
        <p class="footer-line">
          <span>{business.address.full}</span>
          <span class="footer-sep" aria-hidden="true">·</span>
          <a href={`tel:${business.phoneTel}`} data-analytics-event="phone_click">{business.phone}</a>
          <span class="footer-sep" aria-hidden="true">·</span>
          <a href={`mailto:${business.email}`}>{business.email}</a>
        </p>
        <p class="footer-line footer-copyright">
          <span>© {new Date().getFullYear()}</span>
          <span class="footer-sep" aria-hidden="true">·</span>
          <span>In business since {business.inBusinessSince}</span>
          <span class="footer-sep" aria-hidden="true">·</span>
          <span>Temecula since {business.temeculaSince}</span>
        </p>
        <p class="footer-line footer-seo-links">
          <a href="/about-us/">About</a>
          <span class="footer-sep" aria-hidden="true">·</span>
          <a href="/temecula-it-services/">Temecula IT services</a>
          <span class="footer-sep" aria-hidden="true">·</span>
          <a href="/blog/">Blog</a>
          <span class="footer-sep" aria-hidden="true">·</span>
          <a href="/case-studies/">Case studies</a>
        </p>
      </div>
    </footer>

    <QuoteModal />

    <AnalyticsEvents />

    <script is:inline>
      (function () {
        const toggle = document.querySelector(".nav-toggle");
        const menu = document.getElementById("mobile-menu");

        function setMenuOpen(open) {
          if (!toggle || !menu) return;
          toggle.setAttribute("aria-expanded", String(open));
          menu.hidden = !open;
          const label = toggle.querySelector(".nav-toggle-text");
          if (label) label.textContent = open ? "Close" : "Menu";
          document.body.classList.toggle("nav-open", open);
        }

        toggle?.addEventListener("click", function () {
          setMenuOpen(toggle.getAttribute("aria-expanded") !== "true");
        });

        menu?.querySelectorAll("a, [data-open-quote]").forEach(function (link) {
          link.addEventListener("click", function () {
            setMenuOpen(false);
          });
        });

        window.addEventListener("resize", function () {
          if (window.innerWidth > 900) setMenuOpen(false);
        });
      })();
    </script>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
