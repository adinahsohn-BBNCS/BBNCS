---
import { socialLinks } from "../data/site";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;

const icons: Record<(typeof socialLinks)[number]["key"], string> = {
  facebook: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M14 9h3V6h-3c-1.7 0-3 1.3-3 3v2H8v3h2v7h3v-7h2.8l.2-3H13V9c0-.6.4-1 1-1z"/></svg>`,
  twitter: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18.9 4H22l-6.8 7.8L22.7 20h-6.2l-4.9-6.4L5.8 20H2.7l7.3-8.4L2 4h6.3l4.4 5.8L18.9 4zm-1.1 14h1.7L7.1 5.9H5.3L17.8 18z"/></svg>`,
  instagram: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 3h10a4 4 0 0 1 4 4v10a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4V7a4 4 0 0 1 4-4zm10 2H7a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2zm-5 3.5A4.5 4.5 0 1 1 7.5 13 4.5 4.5 0 0 1 12 8.5zm0 2A2.5 2.5 0 1 0 14.5 13 2.5 2.5 0 0 0 12 10.5zM17.8 6.7a1 1 0 1 1-1 1 1 1 0 0 1 1-1z"/></svg>`,
  youtube: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M21.6 7.2a2.5 2.5 0 0 0-1.8-1.8C18 5 12 5 12 5s-6 0-7.8.4A2.5 2.5 0 0 0 2.4 7.2 26 26 0 0 0 2 12a26 26 0 0 0 .4 4.8 2.5 2.5 0 0 0 1.8 1.8C6 19 12 19 12 19s6 0 7.8-.4a2.5 2.5 0 0 0 1.8-1.8A26 26 0 0 0 22 12a26 26 0 0 0-.4-4.8zM10 15.5v-7l6 3.5-6 3.5z"/></svg>`,
  linkedin: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6.5 8.7H3.6V21h2.9V8.7zM5 3a1.7 1.7 0 1 0 0 3.4A1.7 1.7 0 0 0 5 3zM9 8.7H11.8V10h.1c.4-.7 1.3-1.5 2.8-1.5 3 0 3.6 2 3.6 4.6V21h-3v-5.2c0-1.2 0-2.8-1.7-2.8s-2 1.3-2 2.7V21H9V8.7z"/></svg>`,
};
---

<ul class:list={["social-links", className]} aria-label="Social media">
  {
    socialLinks.map((link) => (
      <li>
        <a
          href={link.href}
          class={`social-link social-link--${link.key}`}
          aria-label={link.label}
          target="_blank"
          rel="noopener noreferrer"
        >
          <span class="social-icon" set:html={icons[link.key]} />
        </a>
      </li>
    ))
  }
</ul>
