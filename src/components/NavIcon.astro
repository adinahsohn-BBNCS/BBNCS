---
import type { navLinks } from "../data/site";

interface Props {
  name: (typeof navLinks)[number]["key"];
}

const { name } = Astro.props;
---

<span class="nav-icon" aria-hidden="true">
  {
    name === "home" && (
      <svg viewBox="0 0 24 24">
        <path d="M12 3.2 3 10.5V20a1 1 0 0 0 1 1h6v-6h4v6h6a1 1 0 0 0 1-1v-9.5L12 3.2z" />
      </svg>
    )
  }
  {
    name === "managed-it" && (
      <svg viewBox="0 0 24 24">
        <path d="M4 5a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V5zm4 14h8v2H8v-2z" />
      </svg>
    )
  }
  {
    name === "backup" && (
      <svg viewBox="0 0 24 24">
        <path d="M6.5 18h11a4 4 0 0 0 .4-8 5.5 5.5 0 0 0-10.8-1.4A4 4 0 0 0 6.5 18z" />
      </svg>
    )
  }
  {
    name === "support" && (
      <svg viewBox="0 0 24 24">
        <path d="M12 2a7 7 0 0 0-7 7v4a3 3 0 0 0 3 3h1v5a1 1 0 0 0 1 1h2v-6a3 3 0 0 0 3-3V9a7 7 0 0 0-7-7z" />
      </svg>
    )
  }
  {
    name === "faqs" && (
      <svg viewBox="0 0 24 24">
        <path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zm1 15h-2v-2h2v2zm0-4h-2a3 3 0 1 1 2.8-4 2.9 2.9 0 0 1 .2 1.1 1 1 0 0 1-1 1h-1a1 1 0 0 0 0 2h2a3 3 0 0 0 0-6 3 3 0 0 0-2.8 2.1 1 1 0 0 0 1 1.9z" />
      </svg>
    )
  }
  {
    name === "office" && (
      <svg viewBox="0 0 24 24">
        <path d="M12 2a7 7 0 0 0-7 7c0 5.2 7 13 7 13s7-7.8 7-13a7 7 0 0 0-7-7zm0 9.5A2.5 2.5 0 1 1 14.5 9 2.5 2.5 0 0 1 12 11.5z" />
      </svg>
    )
  }
  {
    name === "contact" && (
      <svg viewBox="0 0 24 24">
        <path d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z" />
      </svg>
    )
  }
</span>
