{
  "name": "bbncs",
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node scripts/copy-sitemap.js",
    "preview": "astro preview",
    "deploy": "powershell -ExecutionPolicy Bypass -File scripts/deploy.ps1",
